# EigenWare external API policy (strict, fail-closed)
allow_http_u8=0
allow_https_u8=1
domains_allowlist_csv=html.duckduckgo.com,dev.epicgames.com,docs.unrealengine.com,forums.unrealengine.com,github.com,raw.githubusercontent.com,objects.githubusercontent.com,release-assets.githubusercontent.com,stackoverflow.com,wikipedia.org,commonvoice.mozilla.org,openslr.org,huggingface.co,cdn-lfs.huggingface.co
