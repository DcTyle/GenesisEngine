{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 18,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "win64-vs2022-clang-vulkan",
      "displayName": "Win64 VS2022 ClangCL + Vulkan",
      "generator": "Visual Studio 17 2022",
      "toolset": "ClangCL",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "architecture": "x64",
      "cacheVariables": {
        "EW_ENABLE_CUDA": "OFF",
        "EW_BUILD_VULKAN_APP": "ON",
        "GENESIS_BUILD_RUNTIME_APP": "ON",
        "GENESIS_INSTALL_EDITOR_APP": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win64-vs2022-clang-vulkan",
      "configurePreset": "win64-vs2022-clang-vulkan",
      "configuration": "Release"
    }
  ]
}
